generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  username             String                @unique
  password             String
  name                 String?
  whatsapp             String?
  createdAt            DateTime              @default(now())
  deletedAt            DateTime?
  updatedAt            DateTime              @default(now()) @updatedAt
  roleId               Int?
  blogComments         BlogComment[]
  blogLikes            BlogLike[]
  blogs                Blog[]
  classFeedbacks       ClassFeedback[]
  discussionLikes      DiscussionLike[]
  discussionReplies    DiscussionReply[]
  discussionReplyLikes DiscussionReplyLike[]
  discussions          Discussion[]
  enrollments          Enrollment[]
  feedbacks            Feedback[]
  reflections           Reflection[]
  role                 Role?                 @relation(fields: [roleId], references: [id])
  trainerFeedbacks     TrainerFeedback[]     @relation("TrainerFeedbackReceiver")
  createdCourses       Course[]              @relation("CourseCreator")
  createdSessions      Session[]             @relation("SessionCreator")

  @@map("users")
}

model Session {
  id            Int          @id @default(autoincrement())
  courseId      Int
  isSynchronous Boolean?
  title         String
  content       Json?
  schedule      Json?
  reference     Json?
  createdBy     Int?
  user          User?        @relation("SessionCreator", fields: [createdBy], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  type          SessionType  @default(SESSION)
  assignments   Assignment[]
  reflections   Reflection[]
  ses           SES[]
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([createdBy])
  @@map("sessions")
}

model Class {
  id                Int             @id @default(autoincrement())
  title             String
  imgUrl            String?
  hours             Int?
  methods           String?
  startDate         DateTime?
  endDate           DateTime?
  description       String?
  learningObjective String?
  isDraft           Boolean         @default(false)
  createdBy         Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  keywords          String[]
  modules           Int?
  previewVideoUrl   String?
  assignments       Assignment[]
  classFeedbacks    ClassFeedback[]
  courses           Course[]
  enrollments       Enrollment[]
  peerFeedbacks     PeerFeedback[]
  trainerFeedbacks  TrainerFeedback[]
  timelines         Timeline[]
  curricula         Curricula[]     @relation("ClassCurricula")

  @@index([createdBy])
  @@index([isDraft])
  @@index([startDate, endDate])
  @@map("classes")
}

model Timeline {
  id        Int       @id @default(autoincrement())
  classId   Int
  date      DateTime
  activity  String
  createdBy Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, date])
  @@index([classId, date])
  @@map("timelines")
}

model Curricula {
  id        Int       @id @default(autoincrement())
  title     String
  fileUrl   String?
  status    String    @default("Active")
  createdBy Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  classes   Class[]   @relation("ClassCurricula")

  @@map("curricula")
}

model Course {
  id                 Int              @id @default(autoincrement())
  classId            Int
  title              String
  description        String?
  learningObjectives String?
  entrySkills        String?
  tools              String?
  createdBy          Int?
  user               User?            @relation("CourseCreator", fields: [createdBy], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?
  threshold          Float?           @default(0)
  type               CourseType       @default(COURSE)
  assignmentItems    AssignmentItem[]
  assignments        Assignment[]
  courseMappings     CourseMapping[]
  class              Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  reflections        Reflection[]
  sessions           Session[]

  @@index([classId])
  @@index([createdBy])
  @@map("courses")
}

model Enrollment {
  id                   Int                @id @default(autoincrement())
  userId               Int
  classId              Int
  status               EnrollmentStatus   @default(ACTIVE)
  enrolledAt           DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?
  cvUrl                String?
  educationField       String?
  finalExpectations    String?
  jobIndustry          String?
  objectives           String[]
  profession           String?
  workField            String?
  yoe                  String?
  assignmentResults    AssignmentResult[]
  classFeedbacks       ClassFeedback[]
  courseMappings       CourseMapping[]
  class                Class              @relation(fields: [classId], references: [id])
  user                 User               @relation(fields: [userId], references: [id])
  groups               Group[]
  learnerAnalytics     LearnerAnalytics?
  peerFeedbackReceiver PeerFeedback[]     @relation("PeerFeedbackReceiver")
  peerFeedbackGiver    PeerFeedback[]     @relation("PeerFeedbackGiver")
  reflections          Reflection[]
  ses                  SES[]
  trainerFeedbacksGiver TrainerFeedback[]     @relation("TrainerFeedbackGiver")

  @@unique([userId, classId])
  @@index([userId])
  @@index([classId])
  @@index([status])
  @@map("enrollments")
}

model SES {
  enrollmentId Int
  sessionId    Int
  score        Float?
  scoredBy     Int?
  scoredAt     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  status       String?    @default("absent")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  session      Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([enrollmentId, sessionId])
  @@index([sessionId])
  @@map("ses")
}

model Reflection {
  id           Int        @id @default(autoincrement())
  sessionId    Int?
  enrollmentId Int
  userId       Int
  content      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  courseId     Int?
  feedback     Feedback?
  course       Course?    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  session      Session?   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, sessionId])
  @@unique([userId, courseId])
  @@index([sessionId])
  @@index([courseId])
  @@index([enrollmentId])
  @@index([userId])
  @@map("reflections")
}

model Feedback {
  id           Int         @id @default(autoincrement())
  reflectionId Int?        @unique
  content      String
  userId       Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  reflection   Reflection? @relation(fields: [reflectionId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id])

  @@index([reflectionId])
  @@index([userId])
  @@map("feedbacks")
}

model Assignment {
  id                Int                @id @default(autoincrement())
  classId           Int?
  courseId          Int?
  sessionId         Int?
  type              AssignmentType
  submissionType    SubmissionType?
  duration          Int?
  startDate         DateTime?
  endDate           DateTime?
  description       String?
  instruction       String?
  passingGrade      Float?
  createdBy         Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  title             String?
  assignmentItems   AssignmentItem[]
  assignmentResults AssignmentResult[]
  class             Class?             @relation(fields: [classId], references: [id])
  course            Course?            @relation(fields: [courseId], references: [id])
  session           Session?           @relation(fields: [sessionId], references: [id])

  @@index([classId])
  @@index([courseId])
  @@index([sessionId])
  @@index([type])
  @@index([startDate, endDate])
  @@map("assignments")
}

model AssignmentItem {
  id                    Int                    @id @default(autoincrement())
  assignmentId          Int
  type                  AssignmentItemType
  question              String
  options               Json?
  correctAnswer         String?
  maxScore              Float?
  createdBy             Int?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now()) @updatedAt
  deletedAt             DateTime?
  courseId              Int?
  assignmentItemResults AssignmentItemResult[]
  assignment            Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  course                Course?                @relation(fields: [courseId], references: [id])

  @@index([assignmentId])
  @@index([courseId])
  @@index([type])
  @@map("assignment_items")
}

model AssignmentResult {
  id                    Int                    @id @default(autoincrement())
  assignmentId          Int
  enrollmentId          Int
  startedAt             DateTime?
  finishedAt            DateTime?
  status                AssignmentStatus       @default(NOT_PASS)
  totalScore            Float?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  feedback              String?
  feedbackFiles         Json?
  assignmentItemResults AssignmentItemResult[]
  assignment            Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  enrollment            Enrollment             @relation(fields: [enrollmentId], references: [id])

  @@unique([assignmentId, enrollmentId])
  @@index([assignmentId])
  @@index([enrollmentId])
  @@map("assignment_results")
}

model AssignmentItemResult {
  id                 Int              @id @default(autoincrement())
  assignmentResultId Int
  assignmentItemId   Int
  answer             String?
  answerFiles        Json?
  score              Float?
  reviewerFeedback   String?
  reviewedBy         Int?
  reviewedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?
  assignmentItem     AssignmentItem   @relation(fields: [assignmentItemId], references: [id])
  assignmentResult   AssignmentResult @relation(fields: [assignmentResultId], references: [id], onDelete: Cascade)

  @@index([assignmentResultId])
  @@index([assignmentItemId])
  @@map("assignment_item_results")
}

model Group {
  id           Int        @id @default(autoincrement())
  enrollmentId Int
  name         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@map("groups")
}

model CourseMapping {
  enrollmentId Int
  courseId     Int
  progress     Float?     @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@id([enrollmentId, courseId])
  @@index([courseId])
  @@map("course_mappings")
}

model Discussion {
  id        Int               @id @default(autoincrement())
  userId    Int
  title     String
  content   String
  type      DiscussionType
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  deletedAt DateTime?
  likes     DiscussionLike[]
  replies   DiscussionReply[]
  user      User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("discussions")
}

model DiscussionReply {
  id           Int                   @id @default(autoincrement())
  discussionId Int
  userId       Int
  text         String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  deletedAt    DateTime?
  discussion   Discussion            @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User                  @relation(fields: [userId], references: [id])
  likes        DiscussionReplyLike[]

  @@index([discussionId])
  @@index([userId])
  @@map("discussion_replies")
}

model DiscussionLike {
  discussionId Int
  userId       Int
  createdAt    DateTime   @default(now())
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@id([discussionId, userId])
  @@index([userId])
  @@map("discussion_likes")
}

model DiscussionReplyLike {
  replyId   Int
  userId    Int
  createdAt DateTime        @default(now())
  reply     DiscussionReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id])

  @@id([replyId, userId])
  @@index([userId])
  @@map("discussion_reply_likes")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  resource    String
  action      String
  description String?
  roles       RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Blog {
  id          Int           @id @default(autoincrement())
  title       String
  bannerUrl   String?
  description String?
  content     Json
  type        String?       @default("General")
  author      Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  comments    BlogComment[]
  likes       BlogLike[]
  user        User          @relation(fields: [author], references: [id])

  @@map("blogs")
}

model BlogComment {
  id        Int       @id @default(autoincrement())
  blogId    Int
  userId    Int
  text      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  blog      Blog      @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@map("blog_comments")
}

model BlogLike {
  blogId    Int
  userId    Int
  createdAt DateTime @default(now())
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@id([blogId, userId])
  @@map("blog_likes")
}

model LearnerAnalytics {
  id                        Int        @id @default(autoincrement())
  enrollmentId              Int        @unique
  cooperationScore          Float?
  cooperationFeedback       String?
  attendanceScore           Float?
  attendanceFeedback        String?
  taskCompletionScore       Float?
  taskCompletionFeedback    String?
  initiativesScore          Float?
  initiativesFeedback       String?
  communicationScore        Float?
  communicationFeedback     String?
  problemUnderstandingScore Float?
  dataReasoningScore        Float?
  methodsScore              Float?
  insightQualityScore       Float?
  solutionQualityScore      Float?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  enrollment                Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@map("learner_analytics")
}

model PeerFeedback {
  id                     Int        @id @default(autoincrement())
  evaluatorId            Int
  evaluateeId            Int
  classId                Int
  cooperation            Int?       @default(0)
  attendance             Int?       @default(0)
  taskCompletion         Int?       @default(0)
  initiatives            Int?       @default(0)
  communication          Int?       @default(0)
  isEdited               Boolean    @default(false)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  attendanceFeedback     String?
  communicationFeedback  String?
  cooperationFeedback    String?
  initiativesFeedback    String?
  taskCompletionFeedback String?
  class                  Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  evaluatee              Enrollment @relation("PeerFeedbackReceiver", fields: [evaluateeId], references: [id], onDelete: Cascade)
  evaluator              Enrollment @relation("PeerFeedbackGiver", fields: [evaluatorId], references: [id], onDelete: Cascade)

  @@unique([evaluatorId, evaluateeId, classId])
  @@map("peer_feedback")
}

model TrainerFeedback {
  id                  Int        @id @default(autoincrement())
  evaluatorId         Int // Enrollment ID of the learner
  trainerId           Int // User ID of the trainer
  classId             Int
  knowledge           Int?       @default(0)
  knowledgeFeedback   String?    @db.Text
  pedagogy            Int?       @default(0)
  pedagogyFeedback    String?    @db.Text
  engagement          Int?       @default(0)
  engagementFeedback  String?    @db.Text
  punctuality         Int?       @default(0)
  punctualityFeedback String?    @db.Text
  isEdited            Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  evaluator Enrollment @relation("TrainerFeedbackGiver", fields: [evaluatorId], references: [id], onDelete: Cascade)
  trainer   User       @relation("TrainerFeedbackReceiver", fields: [trainerId], references: [id], onDelete: Cascade)
  class     Class      @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([evaluatorId, trainerId, classId])
  @@map("trainer_feedback")
}

model ClassFeedback {
  id           Int        @id @default(autoincrement())
  classId      Int
  enrollmentId Int
  userId       Int
  content      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  class        Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, classId])
  @@map("class_feedbacks")
}

enum AssignmentType {
  PLACEMENT
  PRETEST
  POSTTEST
  ASSIGNMENT
  EXERCISE
  PROJECT
}

enum SubmissionType {
  GROUP
  INDIVIDUAL
}

enum AssignmentItemType {
  OBJECTIVE
  ESSAY
  PROJECT
}

enum DiscussionType {
  TECHNICAL_HELP
  LEARNING_RESOURCE
  LEARNING_PARTNER
  COURSE_DISCUSSION
  CAREER_PORTOS
}

enum AssignmentStatus {
  PASS
  NOT_PASS
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum CourseType {
  COURSE
  FINAL_PROJECT
}

enum SessionType {
  SESSION
  EXERCISE
  ASSIGNMENT
}
