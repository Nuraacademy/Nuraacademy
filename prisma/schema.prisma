generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Class {
  classId     Int       @id @default(autoincrement())
  title       String
  imgUrl      String?
  hours       Int?
  methods     String?
  startDate   DateTime?
  endDate     DateTime?
  description String?
  learningObjective String?
  isDraft     Boolean   @default(false)
  createdBy   Int?
  deletedAt   DateTime?

  // Relations
  timelines   Timeline[]
  courses     Course[]
  enrollments Enrollment[]
  assignments Assignment[]

  @@map("classes")
}

model Timeline {
  timelineId Int      @id @default(autoincrement())
  classId    Int
  date       DateTime
  activity   String
  createdBy  Int?
  deletedAt  DateTime?

  class Class @relation(fields: [classId], references: [classId], onDelete: Cascade)

  @@map("timelines")
}

model Course {
  courseId          Int       @id @default(autoincrement())
  classId           Int
  title             String
  description       String?
  learningObjectives String?
  entrySkills       String?
  tools             String?
  createdBy         Int?
  deletedAt         DateTime?

  // Relations
  class      Class     @relation(fields: [classId], references: [classId], onDelete: Cascade)
  sessions   Session[]
  assignments Assignment[]
  courseMappings CourseMapping[]

  @@map("courses")
}

model Session {
  sessionId      Int      @id @default(autoincrement())
  courseId       Int
  isSynchronous  Boolean?
  title          String
  content        Json?
  schedule       Json?
  reference      Json?
  createdBy      Int?
  deletedAt      DateTime?

  course   Course         @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  ses      SES[]
  assignments Assignment[]

  @@map("sessions")
}

model Enrollment {
  enrollmentId Int      @id @default(autoincrement())
  userId       Int
  classId      Int

  class           Class           @relation(fields: [classId], references: [classId])
  ses             SES[]
  assignmentResults AssignmentResult[]
  groups          Group[]
  courseMappings  CourseMapping[]

  @@map("enrollments")
}

model SES {
  enrollmentId Int
  sessionId    Int
  score        Float?
  scoredBy     Int?
  scoredAt     DateTime?

  enrollment Enrollment @relation(fields: [enrollmentId], references: [enrollmentId], onDelete: Cascade)
  session    Session    @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@id([enrollmentId, sessionId])
  @@map("ses")
}

model Assignment {
  assignmentId    Int               @id @default(autoincrement())
  classId         Int?
  courseId        Int?
  sessionId       Int?
  type            String            // placement, pretest, posttest, assignment, exercise, project
  submissionType  String?           // group, individual
  duration        Int?
  startDate       DateTime?
  endDate         DateTime?
  description     String?
  instruction     String?
  passingGrade    Float?
  createdBy       Int?
  deletedAt       DateTime?

  class            Class?               @relation(fields: [classId], references: [classId])
  course           Course?              @relation(fields: [courseId], references: [courseId])
  session          Session?             @relation(fields: [sessionId], references: [sessionId])
  assignmentItems  AssignmentItem[]
  assignmentResults AssignmentResult[]

  @@map("assignments")
}

model AssignmentItem {
  assignmentItemId Int              @id @default(autoincrement())
  assignmentId     Int
  type             String           // objective, essay, project
  question         String
  options          Json?
  correctAnswer    String?
  maxScore         Float?

  assignment           Assignment             @relation(fields: [assignmentId], references: [assignmentId], onDelete: Cascade)
  assignmentItemResults AssignmentItemResult[]

  @@map("assignment_items")
}

model AssignmentResult {
  assignmentResultId Int                 @id @default(autoincrement())
  assignmentId       Int
  enrollmentId       Int
  startedAt          DateTime?
  finishedAt         DateTime?
  status             String              // pass, not_pass

  assignment           Assignment           @relation(fields: [assignmentId], references: [assignmentId], onDelete: Cascade)
  enrollment           Enrollment           @relation(fields: [enrollmentId], references: [enrollmentId])
  assignmentItemResults AssignmentItemResult[]

  @@map("assignment_results")
}

model AssignmentItemResult {
  assignmentItemResultId Int     @id @default(autoincrement())
  assignmentResultId     Int
  assignmentItemId       Int
  answer                 String?
  answerFiles            Json?
  score                  Float?
  reviewerFeedback       String?
  reviewedBy             Int?
  reviewedAt             DateTime?

  assignmentResult AssignmentResult @relation(fields: [assignmentResultId], references: [assignmentResultId], onDelete: Cascade)
  assignmentItem   AssignmentItem   @relation(fields: [assignmentItemId], references: [assignmentItemId])

  @@map("assignment_item_results")
}

model Group {
  groupId      Int         @id @default(autoincrement())
  enrollmentId Int

  enrollment Enrollment @relation(fields: [enrollmentId], references: [enrollmentId], onDelete: Cascade)

  @@map("groups")
}

model CourseMapping {
  enrollmentId Int
  courseId     Int

  enrollment Enrollment @relation(fields: [enrollmentId], references: [enrollmentId], onDelete: Cascade)
  course     Course     @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  @@id([enrollmentId, courseId])
  @@map("course_mappings")
}