//  Settings {
//    database_type: 'PostgreSQL'
//  }
//}

// Main Classes
Table classes {
  class_id int [pk, increment]
  title varchar(255) [not null]
  img_url varchar(500)
  hours int
  methods text
  start_date date
  end_date date
  description text
  learning_objective text
  is_draft boolean [default: false]
  created_by int
  deleted_at timestamp
}

Table timelines {
  timeline_id int [pk, increment]
  class_id int [ref: > classes.class_id]
  date date [not null]
  activity text [not null]
  created_by int
  deleted_at timestamp
}

Table courses {
  course_id int [pk, increment]
  class_id int [ref: > classes.class_id]
  title varchar(255) [not null]
  description text
  learning_objectives text
  entry_skills text
  tools text
  created_by int
  deleted_at timestamp
}

Table sessions {
  session_id int [pk, increment]
  course_id int [ref: > courses.course_id]
  is_synchronous boolean
  title varchar(255) [not null]
  content jsonb
  schedule jsonb
  reference jsonb
  created_by int
  deleted_at timestamp
}

// Enrollment & SES
Table enrollments {
  enrollment_id int [pk, increment]
  user_id int [not null]
  class_id int [ref: > classes.class_id, not null]
}

Table ses {
  enrollment_id int [ref: > enrollments.enrollment_id]
  session_id int [ref: > sessions.session_id]
  score decimal(5,2)
  scored_by int
  scored_at timestamp
  indexes {
    (enrollment_id, session_id) [pk]
  }
}

// Assignments
Table assignments {
  assignment_id int [pk, increment]
  class_id int [ref: > classes.class_id]
  course_id int [ref: > courses.course_id]
  session_id int [ref: > sessions.session_id]
  type varchar(50) [not null, note: 'placement, pretest, posttest, assignment, exercise, project']
  submission_type varchar(20) [note: 'group, individual']
  duration int
  start_date date
  end_date date
  description text
  instruction text
  passing_grade decimal(3,2)
  created_by int
  deleted_at timestamp
}

Table assignment_items {
  assignment_item_id int [pk, increment]
  assignment_id int [ref: > assignments.assignment_id, not null]
  type varchar(20) [not null, note: 'objective, essay, project']
  question text [not null]
  options jsonb
  correct_answer text
  max_score decimal(5,2)
}

Table assignment_results {
  assignment_result_id int [pk, increment]
  assignment_id int [ref: > assignments.assignment_id]
  enrollment_id int [ref: > enrollments.enrollment_id]
  started_at timestamp
  finished_at timestamp
  status varchar(20) [note: 'pass, not_pass']
}

Table assignment_item_results {
  assignment_item_result_id int [pk, increment]
  assignment_result_id int [ref: > assignment_results.assignment_result_id, not null]
  assignment_item_id int [ref: > assignment_items.assignment_item_id]
  answer text
  answer_files jsonb
  score decimal(5,2)
  reviewer_feedback text
  reviewed_by int
  reviewed_at timestamp
}

// Groups and Course Mapping
Table groups {
  group_id int [pk, increment]
  enrollment_id int [ref: > enrollments.enrollment_id]
}

Table course_mappings {
  enrollment_id int [pk, ref: > enrollments.enrollment_id]
  course_id int [ref: > courses.course_id]
}

Ref: enrollments.class_id > classes.class_id // Additional explicit FK
